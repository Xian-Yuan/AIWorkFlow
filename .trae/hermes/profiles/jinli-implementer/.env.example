# Hermes API credentials for jinli-implementer profile
# Copy to .env and fill in your actual keys.
# NEVER commit .env to the repository.

# Required: Model provider API key
# Example (OpenRouter):
# OPENROUTER_API_KEY=your-openrouter-api-key-here

# Required: Model selection
# HERMES_MODEL=deepseek/deepseek-chat
# HERMES_MODEL=anthropic/claude-sonnet-4

# IMPORTANT: Rotate any credential that was previously stored inline.
# See Docs/superpowers/specs/2026-06-19-hermes-workflow-integration-design.md Section 7.
