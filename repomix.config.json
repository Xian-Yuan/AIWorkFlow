{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "input": {
    "maxFileSize": 1048576
  },
  "output": {
    "filePath": "G:/UEGameDevelopment/.tmp/repomix-output.xml",
    "style": "xml",
    "parsableStyle": true,
    "fileSummary": true,
    "directoryStructure": true,
    "files": true,
    "compress": false,
    "topFilesLength": 10,
    "truncateBase64": true,
    "copyToClipboard": false,
    "git": {
      "sortByChanges": true,
      "includeDiffs": false,
      "includeLogs": false
    }
  },
  "ignore": {
    "useGitignore": true,
    "useDotIgnore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      ".tools/**",
      ".tmp/**",
      "**/node_modules/**",
      "**/Binaries/**",
      "**/Intermediate/**",
      "**/Saved/**",
      "**/DerivedDataCache/**",
      "**/*.uasset",
      "**/*.umap",
      "**/*.ubulk",
      "**/*.uexp",
      "**/*.dll",
      "**/*.pdb",
      "**/*.exe",
      "**/*.lib",
      "**/*.obj",
      "**/*.png",
      "**/*.jpg",
      "**/*.jpeg",
      "**/*.webp",
      "**/*.gif",
      "**/*.mp4"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  },
  "tokenCount": {
    "encoding": "o200k_base"
  }
}
